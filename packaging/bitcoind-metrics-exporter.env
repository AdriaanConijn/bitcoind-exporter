# Configuration for bitcoind-metrics-exporter.service
# See: https://git.aads.cloud/aad/bitcoind-metrics-exporter

# RPC_ADDRESS=http://127.0.0.1:8332
# RPC_USER=
# RPC_PASS=
# RPC_COOKIE_FILE=

# ZMQ_ADDRESS must point at bitcoind's zmqpubrawtx port (not zmqpubrawblock) —
# this exporter subscribes to the "rawtx" topic only. Do not include a tcp:// prefix.
# ZMQ_ADDRESS=127.0.0.1:28333

# FETCH_INTERVAL=10

# PROMETHEUS_ENABLED=true
# METRIC_PORT=3000

# OTEL_ENABLED=false
# OTEL_ENDPOINT=

# LOG_LEVEL=info
